    "typeAccelerators": [
        "[math]", "[regex]", "[xml]", "[wmi]", "[wmiclass]", "[wmisearcher]",
        "[adsi]", "[adsisearcher]", "[psobject]", "[pscustomobject]",
        "[scriptblock]", "[type]", "[ipaddress]", "[mailaddress]",
        "[semver]", "[version]", "[guid]", "[uri]", "[timespan]"
