    "eventLogQueries": {
        "codeIntegrity": {
            "logName": "Microsoft-Windows-CodeIntegrity/Operational",
            "eventIds": [3076, 3077, 3089, 3099],
            "descriptions": {
                "3076": "Audit mode block (would have been blocked in enforce)",
                "3077": "Enforce mode block (file was actually blocked)",
                "3089": "Signing information for a file",
                "3099": "Policy refresh event"
            }
        },
        "appLocker": {
            "logName": "Microsoft-Windows-AppLocker/MSI and Script",
            "eventIds": [8003, 8004, 8005, 8006, 8007, 8020, 8023, 8024, 8025],
            "descriptions": {
                "8003": "Exe/DLL was allowed to run",
                "8004": "Exe/DLL was blocked from running",
                "8005": "Script/MSI was allowed to run",
                "8006": "Script/MSI would have been blocked (audit)",
                "8007": "Script/MSI was blocked from running",
                "8020": "Packaged app allowed",
                "8023": "Packaged app was blocked",
                "8024": "Packaged app audit block",
                "8025": "Packaged app installation blocked"
            }
        },
        "powerShell": {
            "logName": "Microsoft-Windows-PowerShell/Operational",
            "eventIds": [4103, 4104, 4105, 4106],
            "descriptions": {
                "4103": "Module logging event",
                "4104": "Script block logging event",
                "4105": "Script block invocation start",
                "4106": "Script block invocation end"
            }
        }
