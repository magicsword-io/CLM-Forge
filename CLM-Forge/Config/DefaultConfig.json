{
    "version": "1.0.0",
    "scriptHostTests": {
        "fileTypes": [
            { "extension": ".ps1",    "host": "powershell.exe", "args": "-ExecutionPolicy Bypass -File", "content": "Write-Output 'CLM-Forge-Test'", "description": "PowerShell script" },
            { "extension": ".bat",    "host": "cmd.exe",        "args": "/c",                            "content": "@echo off\necho CLM-Forge-Test", "description": "Batch file" },
            { "extension": ".cmd",    "host": "cmd.exe",        "args": "/c",                            "content": "@echo off\necho CLM-Forge-Test", "description": "Command file" },
            { "extension": ".vbs",    "host": "cscript.exe",    "args": "//nologo",                      "content": "WScript.Echo \"CLM-Forge-Test\"", "description": "VBScript" },
            { "extension": ".js",     "host": "cscript.exe",    "args": "//nologo",                      "content": "WScript.Echo('CLM-Forge-Test');", "description": "JScript" },
            { "extension": ".jse",    "host": "cscript.exe",    "args": "//nologo",                      "content": "WScript.Echo('CLM-Forge-Test');", "description": "Encoded JScript" },
            { "extension": ".wsf",    "host": "cscript.exe",    "args": "//nologo",                      "content": "<job><script language=\"JScript\">WScript.Echo('CLM-Forge-Test');</script></job>", "description": "Windows Script File" },
            { "extension": ".wsc",    "host": "cscript.exe",    "args": "//nologo",                      "content": "<?xml version=\"1.0\"?><component><public><method name=\"Test\"/></public><script language=\"JScript\"><![CDATA[function Test(){return 'CLM-Forge-Test';}]]></script></component>", "description": "Windows Script Component" },
            { "extension": ".hta",    "host": "mshta.exe",      "args": "",                              "content": "<html><head><script language=\"JScript\">var fso=new ActiveXObject('Scripting.FileSystemObject');close();</script></head></html>", "description": "HTML Application" },
            { "extension": ".ps1xml","host": "powershell.exe", "args": "-ExecutionPolicy Bypass -Command", "content": "", "description": "PowerShell format/type XML" },
            { "extension": ".psc1",   "host": "powershell.exe", "args": "-PSConsoleFile",                "content": "<?xml version=\"1.0\" encoding=\"utf-8\"?><PSConsoleFile ConsoleSchemaVersion=\"1.0\"><PSVersion>5.1</PSVersion></PSConsoleFile>", "description": "PowerShell console file" },
            { "extension": ".mof",    "host": "mofcomp.exe",    "args": "",                              "content": "#pragma autorecover\n[dynamic] class CLMCheckTest {};", "description": "MOF (WMI schema)" }
        ],
        "testPaths": [
            { "path": "$env:TEMP",                                    "description": "User temp directory",         "requiresAdmin": false },
            { "path": "$env:USERPROFILE\\Desktop",                   "description": "User desktop",                "requiresAdmin": false },
            { "path": "$env:USERPROFILE\\Documents",                 "description": "User documents",              "requiresAdmin": false },
            { "path": "$env:USERPROFILE\\Downloads",                 "description": "User downloads",              "requiresAdmin": false },
            { "path": "$env:APPDATA",                                 "description": "Roaming AppData",             "requiresAdmin": false },
            { "path": "$env:LOCALAPPDATA",                            "description": "Local AppData",               "requiresAdmin": false },
            { "path": "$env:LOCALAPPDATA\\Temp",                     "description": "Local AppData Temp",          "requiresAdmin": false },
            { "path": "$env:ProgramData",                             "description": "ProgramData root",            "requiresAdmin": false },
            { "path": "$env:PUBLIC",                                  "description": "Public folder",               "requiresAdmin": false },
            { "path": "C:\\Users\\Public\\Documents",                "description": "Public Documents",            "requiresAdmin": false },
            { "path": "$env:SystemRoot\\Temp",                       "description": "System temp",                 "requiresAdmin": true  },
            { "path": "$env:SystemRoot\\Tasks",                      "description": "Windows Tasks",               "requiresAdmin": true  }
        ],
        "executionMethods": [
            { "method": "direct",          "description": "Direct invocation via script host" },
            { "method": "cmd_c",           "description": "cmd /c <host> <script>" },
            { "method": "powershell_file", "description": "powershell -File <script>" },
            { "method": "powershell_cmd",  "description": "powershell -Command <content>" }
        ]
    },
